# ==================== Django 기본 설정 ==================== #
# Django Secret Key (프로덕션에서는 반드시 변경!)
SECRET_KEY=Django 시크릿 키

# Debug 모드 (프로덕션에서는 False)
DEBUG=True

# 허용할 호스트 (콤마로 구분)
ALLOWED_HOSTS=localhost,127.0.0.1


# ==================== Database (PostgreSQL) ==================== #
DB_NAME=recipick_db
DB_USER=postgres

# 특수문자가 포함된 경우 ""(따옴표) 안에 비밀번호 감쌀 것!
DB_PASSWORD=PostgreSQL 설치 시 자신이 설정한 비밀번호

DB_HOST=localhost
DB_PORT=5432


# ==================== Spoonacular API ==================== #
# Spoonacular API Key (필수!)
SPOONACULAR_API_KEY=본인이 발급받은 Spoonacular API 키


# ==================== CORS 설정 ==================== #
# 프론트엔드 주소 (콤마로 구분, 띄어쓰기 없이)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ==================== Google 소셜 로그인 설정 ==================== #
GOOGLE_CLIENT_ID=Google ID
GOOGLE_CLIENT_SECRET=Google 시크릿 키
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/users/google/callback/

# ==================== Naver 소셜 로그인 설정 ==================== #
NAVER_CLIENT_ID=Naver ID
NAVER_CLIENT_SECRET=Naver 시크릿 키
NAVER_REDIRECT_URI=http://127.0.0.1:8000/users/naver/callback/

# ==================== 카카오 소셜 로그인 설정 ==================== #
KAKAO_CLIENT_ID=카카오 ID
KAKAO_CLIENT_SECRET=카카오 시크릿 키
KAKAO_REDIRECT_URI=http://127.0.0.1:8000/users/kakao/callback/