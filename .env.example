# ==================== Django 기본 설정 ==================== #
# Django Secret Key (프로덕션에서는 반드시 변경!)
SECRET_KEY=시크릿키는_여기에_넣어주세요

# Debug 모드 (프로덕션에서는 False)
DEBUG=True

# 허용할 호스트 (콤마로 구분)
ALLOWED_HOSTS=localhost,127.0.0.1


# ==================== Database (PostgreSQL) ==================== #
DB_NAME=recipick_db
DB_USER=postgres

# 특수문자가 포함된 경우 ""(따옴표) 안에 비밀번호 감쌀 것!
DB_PASSWORD=PostgreSQL 설치 시 자신이 설정한 비밀번호

DB_HOST=localhost
DB_PORT=5432


# ==================== Spoonacular API ==================== #
# Spoonacular API Key (필수!)
SPOONACULAR_API_KEY=실제 Spoonacular API key

# ==================== 농림수산식품교육문화정보원(EPIS) API ==================== #
# 공공데이터포털(data.go.kr)에서 발급. 없으면 sample API(최대 5건) 사용
EPIS_API_KEY=공공데이터포털에서_발급받으세요


# ==================== CORS 설정 ==================== #
# 프론트엔드 주소 (콤마로 구분, 띄어쓰기 없이)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173